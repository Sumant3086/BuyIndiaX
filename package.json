{
  "name": "buyindiax",
  "version": "1.0.0",
  "description": "BuyIndiaX - Modern full-stack MERN e-commerce platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "npm start --prefix client",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "seed": "node scripts/seedProducts.js",
    "build": "cd client && npm ci && npm run build",
    "heroku-postbuild": "npm run build",
    "install-client": "cd client && npm install",
    "build-client": "cd client && npm run build"
  },
  "keywords": ["ecommerce", "mern", "react", "nodejs"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "razorpay": "^2.9.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "express-mongo-sanitize": "^2.2.0",
    "xss-clean": "^0.1.4",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.6.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "@google/generative-ai": "^0.1.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1"
  }
}
