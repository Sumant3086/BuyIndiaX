# ── Required ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/buyindiax
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars

# ── Razorpay (required for payments) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=https://yourapp.com

# ── Admin seed account ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=StrongPassword123!
ADMIN_NAME=Admin

# ── Optional: Redis (free tier at redis.io or Upstash free 10k req/day) ───────
# Leave blank to use built-in in-memory cache (works fine for MVP)
REDIS_URL=

# ── Optional: Google AI (for AI chatbot) ──────────────────────────────────────
GOOGLE_AI_API_KEY=

# ── Optional: Email (use Gmail App Password for free) ─────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password

# ── Optional: Delivery partners ───────────────────────────────────────────────
DELIVERY_PROVIDER=shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
WAREHOUSE_PINCODE=400001
DELHIVERY_TOKEN=

# ── React frontend ────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000/api
